# =============================================================================
# CryptoQuant Environment Variables — copy to .env and fill in real values
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=CryptoQuant
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-here-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://cryptoquant:password@localhost:5432/cryptoquant
POSTGRES_USER=cryptoquant
POSTGRES_PASSWORD=password
POSTGRES_DB=cryptoquant

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Celery
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# -----------------------------------------------------------------------------
# Encryption
# NOTE: Always generate a random IV per encryption operation in application code
# and store it alongside the ciphertext — never reuse a static IV.
# -----------------------------------------------------------------------------
AES_SECRET_KEY=your-aes-256-key-32-chars-here!!

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# -----------------------------------------------------------------------------
# Email (optional)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
